# Copy to web/.env.local (Next.js) and set in Vercel project settings.
# Each key lights up its service — everything degrades gracefully without.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=
OUTREACH_FROM=outreach@dealflow.ai

# Workflows (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Booking is native (no third-party key needed)

# Ava + LLM explanations (Anthropic)
ANTHROPIC_API_KEY=

# AI voice agent (Retell)
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_FROM_NUMBER=

# Direct mail postcards (Lob)
LOB_API_KEY=

# Optional fallback LLM router
OPENROUTER_API_KEY=

# Prospect map
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_SECRET_TOKEN=

# ML service (Phase 4)
ML_SERVICE_URL=http://localhost:8000
